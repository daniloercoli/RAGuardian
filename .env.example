# RAGuardian local environment
# Copy this file to .env for a single-machine development run:
#   cp .env.example .env
#
# This file is safe to copy for local testing. Replace the dev secrets and add
# provider keys before using the app beyond your own machine.

# ---------------------------------------------------------------------------
# 5-minute local defaults
# ---------------------------------------------------------------------------

# Dev-only secrets. Use long random values for shared or production instances.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=dev-only-change-me-min-32-characters
RAG_SECRET_KEY=dev-only-change-me-too-min-32-characters

# No Redis is required for local development.
RAG_STATE_BACKEND=memory
RAG_QUEUE_BACKEND=inline

# Local persistent vector index.
VECTOR_STORE_BACKEND=chroma_persistent
CHROMA_PERSIST_DIR=app/chroma_db

# Local embeddings work on Windows, Linux, and macOS Apple Silicon where the
# runtime installs torch + sentence-transformers. On macOS Intel, use a hosted
# embedding provider from the Admin Configuration page instead.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Local bootstrap login:
#   email: admin@example.local (or leave the email field empty)
#   password: admin
#
# For any shared instance, uncomment one of these and set a real password.
# Preferred: a Werkzeug password hash.
# Generate with:
# python -c "from werkzeug.security import generate_password_hash; import getpass; print(generate_password_hash(getpass.getpass()))"
# RAG_ADMIN_PASSWORD_HASH=
# Dev/plaintext fallback only:
# RAG_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Provider keys
# ---------------------------------------------------------------------------
# The UI starts without provider keys. To ask real questions, configure at least
# one LLM provider in Admin -> Configuration, or uncomment one hosted key here.

# REGOLO_API_KEY=
# MISTRAL_API_KEY=

# Optional legacy/global API key for /api/v1/* clients. Prefer per-user
# workspace API keys from Admin -> API Keys.
# RAG_API_KEY=

# ---------------------------------------------------------------------------
# Local runtime knobs
# ---------------------------------------------------------------------------

# MAX_UPLOAD_SIZE_MB=10
# MAX_AUDIO_UPLOAD_SIZE_MB=50
# RATE_LIMIT_REQUESTS=10
# RATE_LIMIT_WINDOW=60

# LOG_DIR=app/logs
# ENABLE_FILE_LOG=1
# LOG_LEVEL=INFO
# LOG_FORMAT=text
# LOG_TO_CONSOLE=1
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=10
# METRICS_ENABLED=1

# Runtime data paths. Defaults are gitignored.
# UPLOAD_FOLDER=app/uploads
# RAG_DATA_DIR=app/data
# RAG_SETTINGS_FILE=app/data/settings.json
# RAG_FILE_INDEX=app/data/files.json
# RAG_USERS_FILE=app/data/users.json
# RAG_SECRETS_FILE=app/data/secrets.json
# RAG_WORKSPACE_DATA_DIR=app/data/workspaces
# RAG_WORKSPACE_UPLOAD_DIR=app/uploads/workspaces
# RAG_DEFAULT_PROVIDERS_FILE=app/default_providers.json

# ---------------------------------------------------------------------------
# Production-only examples
# ---------------------------------------------------------------------------

# Gunicorn:
# GUNICORN_HOST=127.0.0.1
# GUNICORN_PORT=5000
# GUNICORN_WORKERS=1
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=180
# GUNICORN_RUNTIME_LOG=gunicorn_runtime.log
# GUNICORN_ACCESS_LOG=gunicorn_access.log

# Redis-backed multi-worker/runtime queue mode:
# REDIS_URL=redis://localhost:6379/0
# RAG_STATE_BACKEND=redis
# RAG_QUEUE_BACKEND=redis
# RAG_STATE_PREFIX=rag
# RAG_QUEUE_NAME=rag-default
# RAG_JOB_TTL_SECONDS=86400
# RAG_LOCK_TTL_SECONDS=21600

# Retrieval and generation overrides. Usually set these from the Admin UI.
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=150
# QUERY_K=5
# TEMPERATURE=0.3
# LLM_MODEL=mistral-medium
# RAG_CACHE_ENABLED=true
# RAG_CACHE_TTL=3600
# RAG_USE_INTERNAL_KNOWLEDGE=false

# Optional backups. Disabled unless explicitly enabled.
# BACKUP_ENABLED=0
# BACKUP_DIR=app/backups
# BACKUP_SCHEDULE_HOURS=2,20
# BACKUP_RETENTION_DAYS=7
# BACKUP_REMOTE_TYPE=local
# BACKUP_REMOTE_URL=
# BACKUP_REMOTE_AUTH=

# Optional corporate CA bundle.
# CA_CERT_PATH=
