      "default_model": "Qwen3-Reranker-4B"
    }
  ],
  "voice": [
    {
      "id": "regolo",
      "name": "Regolo Voice",
      "type": "openai_compatible",
      "requires_api_key": true,
      "api_key_env": "REGOLO_API_KEY",
      "base_url": "https://api.regolo.ai/v1",
      "stt_model": "faster-whisper-large-v3",
      "stt_language": "",
      "tts_model": "",
      "voice": "alloy",
      "format": "mp3"
    }
  ],
  "ocr": [
    {
      "id": "regolo",
      "name": "Regolo OCR",
      "type": "openai_compatible",
      "base_url": "https://api.regolo.ai/v1",
      "requires_api_key": true,
      "api_key_env": "REGOLO_API_KEY",
      "models": [
        "deepseek-ocr-2"
