{
  "description": "Built-in providers and models distributed with the project. Regolo and Mistral require their own API keys and are not free services included.",
  "llm": [
    {
      "id": "regolo",
      "name": "Regolo AI",
      "type": "openai_compatible",
      "base_url": "https://api.regolo.ai/v1",
      "requires_api_key": true,
      "api_key_env": "REGOLO_API_KEY",
