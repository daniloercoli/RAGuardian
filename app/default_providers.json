      "models": [
        "gpt-oss-120b",
        "gpt-oss-20b",
        "Llama-3.3-70B-Instruct",
        "gemma4-31b",
        "qwen3.5-122b",
        "qwen3.5-9b",
        "qwen3.6-27b",
        "qwen3-coder-next",
        "apertus-70b",
        "minimax-m2.5",
        "mistral-small-4-119b",
        "brick-v1-beta",
        "Qwen-Image",
        "deepseek-ocr-2"
      ],
      "default_model": "gpt-oss-120b"
    },
    {
      "id": "mistral",
      "name": "Mistral AI",
      "type": "openai_compatible",
      "base_url": "https://api.mistral.ai/v1",
      "requires_api_key": true,
      "api_key_env": "MISTRAL_API_KEY",
