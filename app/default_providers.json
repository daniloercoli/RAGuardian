        "mistral-medium",
        "mistral-small",
        "mistral-large",
        "mistral-tiny",
        "codestral",
        "mistral-large-latest"
      ],
      "default_model": "mistral-medium"
    }
  ],
  "embedding": [
    {
      "id": "regolo",
      "name": "Regolo Embeddings",
      "type": "openai_compatible",
      "base_url": "https://api.regolo.ai/v1",
      "requires_api_key": true,
      "api_key_env": "REGOLO_API_KEY",
      "models": [
        "Qwen3-Embedding-8B"
      ],
      "default_model": "Qwen3-Embedding-8B",
      "dimensions": 1024,
      "privacy_note": "Invia testo dei documenti e query a Regolo."
    }
  ],
  "reranker": [
    {
      "id": "regolo",
      "name": "Regolo Reranker",
      "type": "openai_compatible",
      "base_url": "https://api.regolo.ai/v1",
      "requires_api_key": true,
      "api_key_env": "REGOLO_API_KEY",
